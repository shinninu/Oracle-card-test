}

/* State */
let selectedDeck = "n";
let drawMode = 1;

/* Deck buttons */
document.querySelectorAll('.deck-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.deck-btn').forEach(b => b.className='deck-btn');
    btn.classList.add('active-'+btn.dataset.deck);
    selectedDeck = btn.dataset.deck;
  });
});

/* Mode buttons */
const modeDescs = {
  1: "好きなデッキを選んで1枚引く",
  3: "行動カード1枚 ＋ ランダム2枚",
  6: "頂点：行動カード　中段・下段：ランダム5枚"
};
document.querySelectorAll('.mode-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    drawMode = parseInt(btn.dataset.mode);
    document.getElementById('modeDesc').textContent = modeDescs[drawMode];
    // デッキ選択はモード1のみ有効
    document.getElementById('deckSelector').style.opacity = drawMode===1 ? '1' : '.35';
    document.getElementById('deckSelector').style.pointerEvents = drawMode===1 ? 'auto' : 'none';
  });
});

document.getElementById('drawBtn').addEventListener('click', drawCards);
document.getElementById('resetBtn').addEventListener('click', () => reset(false));

function shuffle(arr){ const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }
function byType(t){ return CARDS.filter(c=>c.type===t); }
function randFrom(arr,n){ return shuffle(arr).slice(0,n); }

function drawCards(){
  reset(true);
  let drawn = [];

  if(drawMode===1){
    const pool = selectedDeck==='all' ? CARDS : byType(selectedDeck);
    drawn = randFrom(pool, 1);
    renderFlat(drawn, false);
  } else if(drawMode===3){
    const action = randFrom(byType('a'), 1);
    const rest   = randFrom(shuffle(CARDS).filter(c=>c.type!=='a'), 2);
    drawn = shuffle([...action, ...rest]);
    renderFlat(drawn, false);
  } else {
    // Pyramid: 頂点=行動1, 中段=ランダム3, 下段=ランダム2
    const top    = randFrom(byType('a'), 1);
    const others = shuffle(CARDS.filter(c=>c.type!=='a'));
    const mid    = others.slice(0,3);
    const bot    = others.slice(3,5);
    drawn = [...top,...mid,...bot];
    renderPyramid(top, mid, bot);
  }

  document.getElementById('tapHint').classList.add('on');
  document.getElementById('resetBtn').classList.add('on');
}

function makeCardEl(card, sm, delay){
  const wrap = document.createElement('div');
  wrap.className = 'card-wrapper' + (sm?' sm':'');
  wrap.style.animationDelay = `${delay}s`;
  wrap.innerHTML = `
    <div class="card-inner">
      <div class="card-face card-back">${backSVG(sm)}</div>
      <div class="card-face card-front ${card.type}">
        <div class="card-art">${frontSVG(card.type,sm)}</div>
        <div class="card-sep"></div>
        <div class="card-name">${card.name}</div>
        <div class="card-en">${card.en}</div>
        <div class="card-type ${card.type}">${TYPE_META[card.type].label}</div>
      </div>
    </div>`;
  wrap.addEventListener('click', ()=>flipCard(wrap, card));
  return wrap;
}

function renderFlat(cards, sm){
  const stage = document.getElementById('stage');
  stage.innerHTML = '';
  cards.forEach((c,i)=> stage.appendChild(makeCardEl(c, sm, i*0.12)));
}

function renderPyramid(top, mid, bot){
  const wrap = document.getElementById('stageWrap');
  wrap.innerHTML = '';
  const pyr = document.createElement('div');
  pyr.className = 'pyramid';

  const rowTop = document.createElement('div'); rowTop.className='pyr-row';
  const rowMid = document.createElement('div'); rowMid.className='pyr-row';
  const rowBot = document.createElement('div'); rowBot.className='pyr-row';

  top.forEach((c,i) => rowTop.appendChild(makeCardEl(c, true, i*0.1)));
  mid.forEach((c,i) => rowMid.appendChild(makeCardEl(c, true, (i+1)*0.12)));
  bot.forEach((c,i) => rowBot.appendChild(makeCardEl(c, true, (i+4)*0.12)));

  pyr.appendChild(rowTop);
  pyr.appendChild(rowMid);
  pyr.appendChild(rowBot);
  wrap.appendChild(pyr);
}

function flipCard(wrap, card){
  if(wrap.classList.contains('flipped')) return;
  wrap.classList.add('flipped');

  const panel = document.getElementById('msgPanel');
  const meta  = TYPE_META[card.type];
  const isAction = card.type==='a';

  const el = document.createElement('div');
  el.className='msg-card';
  el.innerHTML=`
    <div class="msg-head">
      <div class="msg-dot ${card.type}"></div>
      <div class="msg-title">${card.name} — ${card.en}</div>
      <div class="msg-type" style="color:${meta.color}">${meta.label}</div>
    </div>
    <div class="msg-body ${isAction?'a-body':''}">${isAction ? card.msg : `<em>${card.msg}</em>`}</div>`;
  panel.appendChild(el);
  panel.classList.add('on');
}

function reset(silent){
  const wrap = document.getElementById('stageWrap');
  wrap.innerHTML='<div class="stage" id="stage"></div>';
  document.getElementById('msgPanel').innerHTML='';
  document.getElementById('msgPanel').classList.remove('on');
  document.getElementById('tapHint').classList.remove('on');
  if(!silent) document.getElementById('resetBtn').classList.remove('on');
}
</script>
