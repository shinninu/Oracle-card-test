    <rect x="8"  y="8"  width="56" height="56" fill="none" stroke="#A0B8D0" stroke-width=".6" opacity=".42"/>
    <rect x="18" y="18" width="36" height="36" fill="none" stroke="#D4AF5A" stroke-width=".52" opacity=".38" transform="rotate(45 36 36)"/>
    <rect x="24" y="24" width="24" height="24" fill="none" stroke="#A0B8D0" stroke-width=".48" opacity=".32"/>
    <line x1="8"  y1="8"  x2="64" y2="64" stroke="#A0B8D0" stroke-width=".3" opacity=".16"/>
    <line x1="64" y1="8"  x2="8"  y2="64" stroke="#A0B8D0" stroke-width=".3" opacity=".16"/>
    <circle cx="36" cy="36" r="4"   fill="none" stroke="#D4AF5A" stroke-width=".55" opacity=".58"/>
